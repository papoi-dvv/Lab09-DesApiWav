# Ver https://help.github.com/articles/ignoring-files/ para más detalles

# dependencias
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# pruebas
/coverage

# next.js
/.next/
/out/

# producción
/build

# misceláneos
.DS_Store
*.pem
.env.local
.env.development.local
.env.test.local
.env.production.local

# debug / registros
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# archivos de entorno (nunca subir los .local que tienen tus llaves privadas)
.env
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo

# editores de código (opcional pero muy recomendado)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp